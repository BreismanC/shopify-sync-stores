# ===========================================
# Backend Environment Variables
# ===========================================
# Copy this file to .env and fill in the values

# Application
NODE_ENV=development
PORT=3001

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your-db-password
DB_DATABASE=shopify_sync_stores

# Authentication
# IMPORTANT: This MUST match the NEXTAUTH_SECRET in frontend/.env
# The backend uses this secret to verify JWT tokens signed by the frontend
AUTH_SECRET=development-secret-change-in-production

# Frontend URL (for CORS and OAuth callbacks)
FRONTEND_URL=http://localhost:3000

# OAuth Providers (Google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# OAuth Providers (Facebook)
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_CALLBACK_URL=http://localhost:3000/api/auth/facebook/callback

JWT_SECRET=your-jwt-secret-here

# Email Service (Resend)
RESEND_API_KEY=
FROM_EMAIL=no-reply@yourdomain.com

# ===========================================
# MercadoPago — Suscripciones (Preapproval)
# ===========================================
# Token de acceso de MP (MP Dev Home > Tus apps > Credenciales)
# Sandbox: APP_USR-... (test credentials)
# Producción: APP_USR-... (production credentials)
MERCADOPAGO_ACCESS_TOKEN=

# Clave pública de MP (SDK frontend — no se usa en flujo link de pago)
MERCADOPAGO_PUBLIC_KEY=

# Webhook URL de notificación (MP envía IPN a esta URL)
# Local: usa ngrok: ngrok http 3001
# Producción: https://tu-dominio.com/api/webhooks/mercadopago
MERCADOPAGO_NOTIFICATION_URL=http://localhost:3001/api/webhooks/mercadopago

# Modo sandbox (true = testing, false = producción)
MERCADOPAGO_SANDBOX=true

# Moneda de la cuenta MP (ARS, USD, MXN, BRL, COP, CLP, PEN, etc.)
MERCADOPAGO_CURRENCY=ARS

MERCADOPAGO_WEBHOOK_SECRET=

