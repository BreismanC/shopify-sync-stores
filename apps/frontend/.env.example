# ===========================================
# Frontend Environment Variables
# ===========================================
# Copy this file to .env.local and fill in the values
PORT=3000

# NextAuth Configuration
NEXTAUTH_SECRET=your-nextauth-secret-at-least-32-chars
NEXTAUTH_URL=http://localhost:3000

# Backend API URL (NestJS)
# NEXT_PUBLIC_API_URL se usa en código cliente y servidor
# Si se omite, el fallback es http://localhost:3001 (ver apps/frontend/lib/env.ts)
NEXT_PUBLIC_API_URL=http://localhost:3001
JWT_SECRET=