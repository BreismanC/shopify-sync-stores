# ===========================================
# Backend Environment Variables
# ===========================================
# Copy this file to .env and fill in the values

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your-db-password
DB_DATABASE=shopify_sync_stores

# Authentication
# IMPORTANT: This MUST match the NEXTAUTH_SECRET in frontend/.env
# The backend uses this secret to verify JWT tokens signed by the frontend
AUTH_SECRET=development-secret-change-in-production

# Frontend URL (for CORS and callbacks)
FRONTEND_URL=http://localhost:3000

# OAuth Providers (Google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# OAuth Providers (Facebook)
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_CALLBACK_URL=http://localhost:3000/api/auth/facebook/callback

# JWT (legacy - some parts may still use this)
JWT_SECRET=your-jwt-secret-here

# Email Service (Resend)
RESEND_API_KEY=
FROM_EMAIL=no-reply@yourdomain.com

# MercadoPago (for subscriptions)
# MERCADO_PAGO_ACCESS_TOKEN=
# MERCADO_PAGO_PUBLIC_KEY=