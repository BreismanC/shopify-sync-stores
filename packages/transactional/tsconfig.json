{
  "compilerOptions": {
    "target": "ES2023",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationMap": true,
    "removeComments": true,
    "skipLibCheck": true,
    "strict": true,
    "jsx": "react-jsx",
    "outDir": "./dist",
    "rootDir": ".",
    "sourceMap": true,
    "noEmitOnError": false,
    "incremental": true
  },
  "include": [
    "index.ts",
    "emails/**/*.ts",
    "emails/**/*.tsx"
  ]
}
