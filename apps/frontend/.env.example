# ===========================================
# Frontend Environment Variables
# ===========================================
# Copy this file to .env.local and fill in the values

# NextAuth Configuration
NEXTAUTH_SECRET=your-nextauth-secret-at-least-32-chars
NEXTAUTH_URL=http://localhost:3000

# Backend URL (where the NestJS API runs)
BACKEND_URL=http://localhost:3001
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001

# Optional: Database URL for Prisma (if using)
DATABASE_URL=postgresql://user:password@localhost:5432/shopify_sync_stores

# Optional: Feature flags
# NEXT_PUBLIC_FEATURE_X=true